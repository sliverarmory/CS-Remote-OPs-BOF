{
    "name": "Add User (Remote)",
    "package_name": "remote-adduser",
    "version": "0.0.0",
    "extension_author": "TrustedSec",
    "original_author": "TrustedSec",
    "repo_url": "https://github.com/sliverarmory/CS-Remote-OPs-BOF",
    "commands": [
        {
            "command_name": "remote-adduser",
            "help": "Add a new user to a local or remote machine",
            "long_help": "Creates a new user account on the specified machine using NetUserAdd. If no server is specified, the user is created on the local machine.",
            "depends_on": "coff-loader",
            "entrypoint": "go",
            "files": [
                {
                    "os": "windows",
                    "arch": "amd64",
                    "path": "adduser.x64.o"
                },
                {
                    "os": "windows",
                    "arch": "386",
                    "path": "adduser.x86.o"
                }
            ],
            "arguments": [
                {
                    "name": "username",
                    "desc": "Name of the new user account",
                    "type": "wstring",
                    "optional": false
                },
                {
                    "name": "password",
                    "desc": "Password for the new user account",
                    "type": "wstring",
                    "optional": false
                },
                {
                    "name": "server",
                    "desc": "Target machine. Omit for local machine",
                    "type": "wstring",
                    "optional": true,
                    "default": ""
                }
            ]
        }
    ]
}
