{
    "name": "Process Dump (Remote)",
    "package_name": "remote-procdump",
    "version": "0.0.0",
    "extension_author": "TrustedSec",
    "original_author": "TrustedSec",
    "repo_url": "https://github.com/sliverarmory/CS-Remote-OPs-BOF",
    "commands": [
        {
            "command_name": "remote-procdump",
            "help": "Dump a process to a file on disk",
            "long_help": "Creates a minidump of the specified process using MiniDumpWriteDump and writes it to the specified path on the target.",
            "depends_on": "coff-loader",
            "entrypoint": "go",
            "files": [
                {
                    "os": "windows",
                    "arch": "amd64",
                    "path": "procdump.x64.o"
                },
                {
                    "os": "windows",
                    "arch": "386",
                    "path": "procdump.x86.o"
                }
            ],
            "arguments": [
                {
                    "name": "pid",
                    "desc": "Process ID to dump",
                    "type": "integer",
                    "optional": false
                },
                {
                    "name": "output-path",
                    "desc": "File path on target to write the dump to",
                    "type": "wstring",
                    "optional": false
                }
            ]
        }
    ]
}
