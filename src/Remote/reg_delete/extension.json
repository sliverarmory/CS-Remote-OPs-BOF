{
    "name": "Registry Delete (Remote)",
    "package_name": "remote-reg-delete",
    "version": "0.0.0",
    "extension_author": "TrustedSec",
    "original_author": "TrustedSec",
    "repo_url": "https://github.com/sliverarmory/CS-Remote-OPs-BOF",
    "commands": [
        {
            "command_name": "remote-reg-delete",
            "help": "Delete a registry key or value",
            "long_help": "Deletes a registry value or an entire key on a local or remote machine using RegDeleteValueA or RegDeleteKeyA.",
            "depends_on": "coff-loader",
            "entrypoint": "go",
            "files": [
                {
                    "os": "windows",
                    "arch": "amd64",
                    "path": "reg_delete.x64.o"
                },
                {
                    "os": "windows",
                    "arch": "386",
                    "path": "reg_delete.x86.o"
                }
            ],
            "arguments": [
                {
                    "name": "hostname",
                    "desc": "Target machine. Empty string for local machine",
                    "type": "string",
                    "optional": true,
                    "default": ""
                },
                {
                    "name": "hive",
                    "desc": "Registry hive: 0=HKCR, 1=HKCU, 2=HKLM, 3=HKU",
                    "type": "integer",
                    "optional": false,
                    "choices": ["0", "1", "2", "3"]
                },
                {
                    "name": "path",
                    "desc": "Registry key path",
                    "type": "string",
                    "optional": false
                },
                {
                    "name": "value",
                    "desc": "Value name to delete. Empty string when deleting an entire key",
                    "type": "string",
                    "optional": true,
                    "default": ""
                },
                {
                    "name": "delete-key",
                    "desc": "Set to 1 to delete the entire key instead of a value: 0=no, 1=yes",
                    "type": "integer",
                    "optional": true,
                    "default": 0
                }
            ]
        }
    ]
}
