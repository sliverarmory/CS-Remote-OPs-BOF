{
    "name": "Process List Handles (Remote)",
    "package_name": "remote-process-list-handles",
    "version": "0.0.0",
    "extension_author": "TrustedSec",
    "original_author": "TrustedSec",
    "repo_url": "https://github.com/sliverarmory/CS-Remote-OPs-BOF",
    "commands": [
        {
            "command_name": "remote-process-list-handles",
            "help": "List the open handles of a process",
            "long_help": "Enumerates all handles held by the specified process using NtQuerySystemInformation and NtQueryObject. Reports handle type, value, and name for each handle.",
            "depends_on": "coff-loader",
            "entrypoint": "go",
            "files": [
                {
                    "os": "windows",
                    "arch": "amd64",
                    "path": "ProcessListHandles.x64.o"
                },
                {
                    "os": "windows",
                    "arch": "386",
                    "path": "ProcessListHandles.x86.o"
                }
            ],
            "arguments": [
                {
                    "name": "pid",
                    "desc": "Process ID to list handles for",
                    "type": "integer",
                    "optional": false
                }
            ]
        }
    ]
}
