{
    "name": "Service Description (Remote)",
    "package_name": "remote-sc-description",
    "version": "0.0.0",
    "extension_author": "TrustedSec",
    "original_author": "TrustedSec",
    "repo_url": "https://github.com/sliverarmory/CS-Remote-OPs-BOF",
    "commands": [
        {
            "command_name": "remote-sc-description",
            "help": "Change the description of a service on a local or remote machine",
            "long_help": "Modifies the description of an existing Windows service using ChangeServiceConfig2A.",
            "depends_on": "coff-loader",
            "entrypoint": "go",
            "files": [
                {
                    "os": "windows",
                    "arch": "amd64",
                    "path": "sc_description.x64.o"
                },
                {
                    "os": "windows",
                    "arch": "386",
                    "path": "sc_description.x86.o"
                }
            ],
            "arguments": [
                {
                    "name": "hostname",
                    "desc": "Target machine. Empty string for local machine",
                    "type": "string",
                    "optional": true,
                    "default": ""
                },
                {
                    "name": "service-name",
                    "desc": "Name of the service to modify",
                    "type": "string",
                    "optional": false
                },
                {
                    "name": "description",
                    "desc": "New description text for the service",
                    "type": "string",
                    "optional": false
                }
            ]
        }
    ]
}
