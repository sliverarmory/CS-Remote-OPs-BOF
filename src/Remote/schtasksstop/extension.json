{
    "name": "Scheduled Task Stop (Remote)",
    "package_name": "remote-schtasks-stop",
    "version": "0.0.0",
    "extension_author": "TrustedSec",
    "original_author": "TrustedSec",
    "repo_url": "https://github.com/sliverarmory/CS-Remote-OPs-BOF",
    "commands": [
        {
            "command_name": "remote-schtasks-stop",
            "help": "Stop a running scheduled task on a local or remote machine",
            "long_help": "Stops a currently running scheduled task using the IRegisteredTask::Stop COM interface.",
            "depends_on": "coff-loader",
            "entrypoint": "go",
            "files": [
                {
                    "os": "windows",
                    "arch": "amd64",
                    "path": "schtasksstop.x64.o"
                },
                {
                    "os": "windows",
                    "arch": "386",
                    "path": "schtasksstop.x86.o"
                }
            ],
            "arguments": [
                {
                    "name": "hostname",
                    "desc": "Target machine. Empty string for local machine",
                    "type": "wstring",
                    "optional": true,
                    "default": ""
                },
                {
                    "name": "taskpath",
                    "desc": "Full path to the task to stop",
                    "type": "wstring",
                    "optional": false
                }
            ]
        }
    ]
}
