{
    "name": "Service Config (Remote)",
    "package_name": "remote-sc-config",
    "version": "0.0.0",
    "extension_author": "TrustedSec",
    "original_author": "TrustedSec",
    "repo_url": "https://github.com/sliverarmory/CS-Remote-OPs-BOF",
    "commands": [
        {
            "command_name": "remote-sc-config",
            "help": "Configure an existing service on a local or remote machine",
            "long_help": "Modifies the configuration of an existing service using ChangeServiceConfigA. Can change the binary path, error mode, and start mode.",
            "depends_on": "coff-loader",
            "entrypoint": "go",
            "files": [
                {
                    "os": "windows",
                    "arch": "amd64",
                    "path": "sc_config.x64.o"
                },
                {
                    "os": "windows",
                    "arch": "386",
                    "path": "sc_config.x86.o"
                }
            ],
            "arguments": [
                {
                    "name": "hostname",
                    "desc": "Target machine. Empty string for local machine",
                    "type": "string",
                    "optional": true,
                    "default": ""
                },
                {
                    "name": "service-name",
                    "desc": "Name of the service to configure",
                    "type": "string",
                    "optional": false
                },
                {
                    "name": "binpath",
                    "desc": "New binary path for the service",
                    "type": "string",
                    "optional": false
                },
                {
                    "name": "error-mode",
                    "desc": "Error mode: 0=ignore, 1=normal, 2=severe, 3=critical",
                    "type": "short",
                    "optional": false,
                    "choices": ["0", "1", "2", "3"]
                },
                {
                    "name": "start-mode",
                    "desc": "Start mode: 2=auto, 3=demand, 4=disabled",
                    "type": "short",
                    "optional": false,
                    "choices": ["2", "3", "4"]
                }
            ]
        }
    ]
}
