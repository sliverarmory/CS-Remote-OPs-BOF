{
    "name": "Unexpire User (Remote)",
    "package_name": "remote-unexpireuser",
    "version": "0.0.0",
    "extension_author": "TrustedSec",
    "original_author": "TrustedSec",
    "repo_url": "https://github.com/sliverarmory/CS-Remote-OPs-BOF",
    "commands": [
        {
            "command_name": "remote-unexpireuser",
            "help": "Set a user account to never expire",
            "long_help": "Sets the account expiration to never expire using NetUserSetInfo with USER_INFO_1017. Specify an empty server to target the local machine.",
            "depends_on": "coff-loader",
            "entrypoint": "go",
            "files": [
                {
                    "os": "windows",
                    "arch": "amd64",
                    "path": "unexpireuser.x64.o"
                },
                {
                    "os": "windows",
                    "arch": "386",
                    "path": "unexpireuser.x86.o"
                }
            ],
            "arguments": [
                {
                    "name": "server",
                    "desc": "Target machine. Empty string for local machine",
                    "type": "wstring",
                    "optional": true,
                    "default": ""
                },
                {
                    "name": "username",
                    "desc": "User account to set as never-expiring",
                    "type": "wstring",
                    "optional": false
                }
            ]
        }
    ]
}
