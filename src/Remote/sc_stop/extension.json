{
    "name": "Service Stop (Remote)",
    "package_name": "remote-sc-stop",
    "version": "0.0.0",
    "extension_author": "TrustedSec",
    "original_author": "TrustedSec",
    "repo_url": "https://github.com/sliverarmory/CS-Remote-OPs-BOF",
    "commands": [
        {
            "command_name": "remote-sc-stop",
            "help": "Stop a service on a local or remote machine",
            "long_help": "Stops a running Windows service using ControlService with SERVICE_CONTROL_STOP.",
            "depends_on": "coff-loader",
            "entrypoint": "go",
            "files": [
                {
                    "os": "windows",
                    "arch": "amd64",
                    "path": "sc_stop.x64.o"
                },
                {
                    "os": "windows",
                    "arch": "386",
                    "path": "sc_stop.x86.o"
                }
            ],
            "arguments": [
                {
                    "name": "hostname",
                    "desc": "Target machine. Empty string for local machine",
                    "type": "string",
                    "optional": true,
                    "default": ""
                },
                {
                    "name": "service-name",
                    "desc": "Name of the service to stop",
                    "type": "string",
                    "optional": false
                }
            ]
        }
    ]
}
