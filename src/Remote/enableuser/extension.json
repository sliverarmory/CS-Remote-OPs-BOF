{
    "name": "Enable User (Remote)",
    "package_name": "remote-enable-user",
    "version": "0.0.0",
    "extension_author": "TrustedSec",
    "original_author": "TrustedSec",
    "repo_url": "https://github.com/sliverarmory/CS-Remote-OPs-BOF",
    "commands": [
        {
            "command_name": "remote-enable-user",
            "help": "Unlock and enable a local or remote user account",
            "long_help": "Enables and unlocks a user account by clearing the UF_ACCOUNTDISABLE and UF_LOCKOUT flags via NetUserSetInfo. Specify an empty server to target the local machine, or a domain controller for domain accounts.",
            "depends_on": "coff-loader",
            "entrypoint": "go",
            "files": [
                {
                    "os": "windows",
                    "arch": "amd64",
                    "path": "enableuser.x64.o"
                },
                {
                    "os": "windows",
                    "arch": "386",
                    "path": "enableuser.x86.o"
                }
            ],
            "arguments": [
                {
                    "name": "server",
                    "desc": "Target machine or DC for domain accounts. Empty string for local machine",
                    "type": "wstring",
                    "optional": true,
                    "default": ""
                },
                {
                    "name": "username",
                    "desc": "User account to unlock and enable",
                    "type": "wstring",
                    "optional": false
                }
            ]
        }
    ]
}
