{
    "name": "Make Token Cert (Remote)",
    "package_name": "remote-make_token_cert",
    "version": "0.0.0",
    "extension_author": "c2biz",
    "original_author": "TrustedSec",
    "repo_url": "https://github.com/sliverarmory/CS-Remote-OPs-BOF",
    "commands": [
        {
            "command_name": "remote-make_token_cert",
            "help": "Create an impersonation token from a certificate PFX file",
            "long_help": "Reads a PFX certificate file, imports it into the current user's certificate store, creates an impersonation token based on the certificate's Alt Name via PKINIT, then removes the certificate from the store. Useful for leveraging ADCS-obtained certificates for authentication.",
            "depends_on": "coff-loader",
            "entrypoint": "go",
            "files": [
                {
                    "os": "windows",
                    "arch": "amd64",
                    "path": "make_token_cert.x64.o"
                },
                {
                    "os": "windows",
                    "arch": "386",
                    "path": "make_token_cert.x86.o"
                }
            ],
            "arguments": [
                {
                    "name": "pfx",
                    "desc": "Path to PFX certificate file",
                    "type": "file",
                    "optional": false
                },
                {
                    "name": "password",
                    "desc": "Password to decrypt the PFX. Omit if no password",
                    "type": "wstring",
                    "optional": true,
                    "default": ""
                }
            ]
        }
    ]
}
