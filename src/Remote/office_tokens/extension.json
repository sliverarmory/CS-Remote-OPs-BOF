{
    "name": "Office Tokens (Remote)",
    "package_name": "remote-office-tokens",
    "version": "0.0.0",
    "extension_author": "TrustedSec",
    "original_author": "TrustedSec",
    "repo_url": "https://github.com/sliverarmory/CS-Remote-OPs-BOF",
    "commands": [
        {
            "command_name": "remote-office-tokens",
            "help": "Search a process's memory for Office JWT access tokens",
            "long_help": "Reads the memory of the specified process and searches for Microsoft Office JWT access tokens. Target a process that handles Office authentication (e.g., Microsoft Office apps).",
            "depends_on": "coff-loader",
            "entrypoint": "go",
            "files": [
                {
                    "os": "windows",
                    "arch": "amd64",
                    "path": "office_tokens.x64.o"
                },
                {
                    "os": "windows",
                    "arch": "386",
                    "path": "office_tokens.x86.o"
                }
            ],
            "arguments": [
                {
                    "name": "pid",
                    "desc": "Process ID to search for Office tokens",
                    "type": "integer",
                    "optional": false
                }
            ]
        }
    ]
}
