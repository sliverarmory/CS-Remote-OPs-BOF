{
    "name": "NtQueueApcThread Inject (Injection)",
    "package_name": "inject-ntqueueapcthread",
    "version": "v0.0.0",
    "extension_author": "0xbad53c",
    "original_author": "TrustedSec",
    "repo_url": "https://github.com/sliverarmory/CS-Remote-OPs-BOF",
    "commands": [
        {
            "command_name": "inject-ntqueueapcthread",
            "help": "Inject shellcode into a process via NtQueueApcThread syscall",
            "long_help": "Injects shellcode into a target process using the NtQueueApcThread technique with direct syscalls loaded from ntdll on disk. Uses section mapping to write shellcode and queues an APC to a target thread for execution.",
            "depends_on": "coff-loader",
            "entrypoint": "go",
            "files": [
                {
                    "os": "windows",
                    "arch": "amd64",
                    "path": "ntqueueapcthread.x64.o"
                },
                {
                    "os": "windows",
                    "arch": "386",
                    "path": "ntqueueapcthread.x86.o"
                }
            ],
            "arguments": [
                {
                    "name": "pid",
                    "desc": "Target process ID",
                    "type": "integer",
                    "optional": false
                },
                {
                    "name": "bin",
                    "desc": "Path to shellcode file",
                    "type": "file",
                    "optional": false
                }
            ]
        }
    ]
}
