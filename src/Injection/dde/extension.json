{
    "name": "DDE Inject (Injection)",
    "package_name": "inject-dde",
    "version": "v0.0.0",
    "extension_author": "0xbad53c",
    "original_author": "TrustedSec",
    "repo_url": "https://github.com/sliverarmory/CS-Remote-OPs-BOF",
    "commands": [
        {
            "command_name": "inject-dde",
            "help": "Inject shellcode into explorer.exe via DDE window class",
            "long_help": "Injects shellcode into explorer.exe using the DDE (Dynamic Data Exchange) technique with direct syscalls loaded from ntdll on disk. Targets explorer.exe only — no PID required. WARNING: This technique causes the shellcode to execute FOUR times, so plan accordingly. Ensure your shellcode will not kill the process or thread.",
            "depends_on": "coff-loader",
            "entrypoint": "go",
            "files": [
                {
                    "os": "windows",
                    "arch": "amd64",
                    "path": "dde.x64.o"
                },
                {
                    "os": "windows",
                    "arch": "386",
                    "path": "dde.x86.o"
                }
            ],
            "arguments": [
                {
                    "name": "bin",
                    "desc": "Path to shellcode file",
                    "type": "file",
                    "optional": false
                }
            ]
        }
    ]
}
