{
    "name": "KernelCallbackTable Inject (Injection)",
    "package_name": "inject-kernelcallbacktable",
    "version": "v0.0.0",
    "extension_author": "0xbad53c",
    "original_author": "TrustedSec",
    "repo_url": "https://github.com/sliverarmory/CS-Remote-OPs-BOF",
    "commands": [
        {
            "command_name": "inject-kernelcallbacktable",
            "help": "Inject shellcode via PEB KernelCallbackTable hijack",
            "long_help": "Injects shellcode by hijacking the KernelCallbackTable pointer in the target process's PEB using direct syscalls loaded from ntdll on disk. Triggers execution via WM_COPYDATA message. Can only target processes that handle window messages (GUI processes).",
            "depends_on": "coff-loader",
            "entrypoint": "go",
            "files": [
                {
                    "os": "windows",
                    "arch": "amd64",
                    "path": "kernelcallbacktable.x64.o"
                },
                {
                    "os": "windows",
                    "arch": "386",
                    "path": "kernelcallbacktable.x86.o"
                }
            ],
            "arguments": [
                {
                    "name": "pid",
                    "desc": "Target process ID (must be a GUI process that handles window messages)",
                    "type": "integer",
                    "optional": false
                },
                {
                    "name": "bin",
                    "desc": "Path to shellcode file",
                    "type": "file",
                    "optional": false
                }
            ]
        }
    ]
}
